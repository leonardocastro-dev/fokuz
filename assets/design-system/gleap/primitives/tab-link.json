{
  "name": "tab-link",
  "description": "Tab navigation link used in feature grid for switching between feature views",
  "anatomy": {
    "slots": ["label"],
    "required": ["label"]
  },
  "base": {
    "display": "inline-flex",
    "alignItems": "center",
    "padding": "spacing.2 spacing.4",
    "borderRadius": "radii.md",
    "fontSize": "body-sm",
    "fontWeight": 400,
    "fontFamily": "system",
    "lineHeight": "1.5",
    "cursor": "pointer",
    "transition": "motion.hover",
    "textDecoration": "none"
  },
  "variants": {
    "base": {
      "background": "transparent",
      "color": "black.900",
      "border": "none"
    }
  },
  "states": {
    "hover": {
      "background": "white.200",
      "inferred": false
    },
    "active": {
      "background": "black.900",
      "color": "white.50",
      "fontWeight": 500,
      "inferred": false
    },
    "disabled": {
      "opacity": "0.5",
      "cursor": "not-allowed",
      "inferred": true
    }
  },
  "sizes": {},
  "icon": null
}
